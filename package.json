    "tsx": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.4",
    "typescript": "~5.9.3"
  }
}
